# Anthropic (LLM agent — only called for ambiguous signals, ~10-50 calls/day)
ANTHROPIC_API_KEY=your_key_here

# ThetaData (equity options Greeks + chain snapshots)
THETADATA_API_KEY=your_key_here

# Databento (CME futures MBO/trades — GLBX.MDP3)
DATABENTO_API_KEY=your_key_here

# ── Broker: Tradier — equity options and stocks ───────────────────────────────
TRADIER_TOKEN=your_bearer_token_here
TRADIER_ACCOUNT_ID=your_account_id_here   # found in Tradier dashboard
TRADIER_SANDBOX=true                       # true = sandbox, false = live

# ── Broker: Tradovate — futures (via funded account) ─────────────────────────
# Get CID and SECRET from Tradovate developer portal (demo.tradovate.com)
TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_CID=0                            # client ID from developer portal
TRADOVATE_SECRET=your_secret_here
TRADOVATE_DEVICE_ID=                       # leave empty to auto-generate UUID
TRADOVATE_DEMO=true                        # true = demo, false = live

# ── Instruments ───────────────────────────────────────────────────────────────
EQUITY_ROOTS=SPY,QQQ,AAPL,NVDA            # option roots (ThetaData)
CME_SYMBOLS=ES.FUT,NQ.FUT                 # futures (Databento)

# ── IPC ───────────────────────────────────────────────────────────────────────
ZMQ_ENDPOINT=ipc:///tmp/zeta.sock         # Julia PUSH → Rust PULL

# ── Persistence ───────────────────────────────────────────────────────────────
OMS_LOG_PATH=/var/log/trading/oms.jsonl   # append-only event log

# ── Zeta Field parameters ─────────────────────────────────────────────────────
PORTFOLIO_VALUE=100000                     # total capital for Kelly sizing
FIELD_INTERVAL_SEC=60                      # seconds between field computations
GARCH_WINDOW=252                           # trading days for GARCH fitting
HMM_REGIMES=3                              # 3 = low / normal / stress
VRP_ZSCORE_THRESHOLD=1.5                   # min z-score to consider VRP significant
DELTA_HEDGE_TOLERANCE=0.05                 # max net delta before re-hedge
TARGET_DELTA=0.0                           # target portfolio delta
LOG_LEVEL=info                             # info | debug
