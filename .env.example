# ThetaData (equity options, indices)
THETADATA_API_KEY=your_key_here

# Databento (CME futures + options on futures)
DATABENTO_API_KEY=your_key_here

# Broker — Alpaca (paper or live)
ALPACA_KEY_ID=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true   # set to false for live trading

# Instruments to trade
EQUITY_ROOTS=SPY,QQQ,AAPL,NVDA   # comma-separated option roots (ThetaData)
CME_SYMBOLS=ES.FUT,NQ.FUT         # comma-separated futures (Databento)

# Zeta Field parameters
GARCH_WINDOW=252           # trading days for GARCH fitting
HMM_REGIMES=3              # number of hidden regimes (2=low/high, 3=low/normal/stress)
VRP_ZSCORE_THRESHOLD=1.5   # Z-score above which VRP is "significant"
DELTA_HEDGE_TOLERANCE=0.05 # max net delta before re-hedge triggers
TARGET_DELTA=0.0           # target portfolio delta (0 = delta-neutral)
